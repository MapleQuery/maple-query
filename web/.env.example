# Cloud Run agent-service URL (no trailing slash).
NEXT_PUBLIC_MAPLEQUERY_API_BASE_URL=https://agent-service-f2ihvaiw6q-uc.a.run.app

# Bearer token — pull from GCP Secret Manager:
#   gcloud secrets versions access latest --secret=mqagent-api-token --project=maplequery
NEXT_PUBLIC_MAPLEQUERY_API_TOKEN=

# Env label. Vercel auto-injects VERCEL_ENV; this is a manual override for local dev.
NEXT_PUBLIC_MAPLEQUERY_ENV=dev
